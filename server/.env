# ================================
# APP SETTINGS
# ================================
APP_NAME=AI Resume Analyzer
APP_VERSION=1.0.0
DEBUG=True

# ================================
# API CONFIG
# ================================
API_PREFIX=/api

# ================================
# FILE UPLOAD SETTINGS
# ================================
MAX_FILE_SIZE_MB=5

# ================================
# CORS (comma separated in production)
# ================================
ALLOWED_ORIGINS=*

# ================================
# AI KEYS (OPTIONAL)
# ================================
OPENAI_API_KEY=
GEMINI_API_KEY=

# ================================
# DATABASE (future use)
# ================================
DATABASE_URL=

# ================================
# LOGGING
# ================================
LOG_LEVEL=INFO